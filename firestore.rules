rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Products collection: Read only for everyone, Write for Admins (simplified)
    match /products/{productId} {
      allow read: if true;
      allow write: if false; // Assuming products are seeded manually or via admin which we don't have yet
    }

    // User profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.email is string && 
               data.email.size() <= 256 &&
               data.keys().hasAll(['email']) &&
               data.keys().size() <= 5;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                    incoming().email == existing().email;
    }

    // Cart items
    match /users/{userId}/cart/{itemId} {
      function isValidCartItem(data) {
        return data.productId is string &&
               data.productId.size() <= 128 &&
               data.quantity is int &&
               data.quantity > 0 &&
               data.quantity <= 100 &&
               data.addedAt is string;
      }

      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidCartItem(incoming());
      allow update: if isOwner(userId) && isValidCartItem(incoming());
      allow delete: if isOwner(userId);
    }
    
    // Connection test document
    match /test/connection {
      allow read: if true;
    }
  }
}
