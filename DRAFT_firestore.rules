rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Product Validation ---
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'imageUrl', 'category']) &&
             data.keys().size() >= 4 && data.keys().size() <= 10 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.imageUrl is string && data.imageUrl.size() > 0 &&
             data.category is string && (data.stock == null || data.stock is int) &&
             (data.isGift == null || data.isGift is bool);
    }

    // --- Cart Validation ---
    function isValidCartItem(data) {
      return data.keys().hasAll(['productId', 'quantity', 'addedAt']) &&
             data.keys().size() == 3 &&
             data.productId is string &&
             data.quantity is int && data.quantity > 0 &&
             data.addedAt is string; // Using format: 'date-time' usually enforced by client, but string check here
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string && data.email == request.auth.token.email;
    }

    // --- Collections ---

    match /products/{productId} {
      allow read: if true; // Public catalog
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) &&
                    isValidUser(incoming());
    }

    match /users/{userId}/cart/{itemId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isValidCartItem(incoming());
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console or server-side only
    }
  }
}
